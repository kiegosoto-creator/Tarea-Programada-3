        valorEspacios = str(configActual["total_espacios"]) if configActual["total_espacios"] > 0 else ""
        valorGracia = str(configActual["tiempo_gracia"])
        valorMonto = str(configActual["monto_por_hora"])
        valorElectrico = configActual["tiene_electrico"]

        var_espacios = tk.StringVar(value=valorEspacios)
        var_gracia = tk.StringVar(value=valorGracia)
        var_monto = tk.StringVar(value=valorMonto)
        var_electrico = tk.BooleanVar(value=valorElectrico)

        if configActual["total_espacios"] > 0:
            textoTitulo = "Configuracion actual del Estacionamiento"
            textoSubtitulo = "Puede modificar los valores y guardar."
        else:
            textoTitulo = "Configuracion del Estacionamiento"
            textoSubtitulo = "No se encontro una base de datos.\nIngrese los datos de configuracion:"

        tk.Label(ventana, text=textoTitulo,
            font=("Arial", 14, "bold"), bg="#f0f0f0").pack(pady=15)
        tk.Label(ventana, text=textoSubtitulo,
            font=("Arial", 11), bg="#f0f0f0").pack(pady=5)

        frame = tk.Frame(ventana, bg="#f0f0f0")
        frame.pack(pady=20, padx=40)

        tk.Label(frame, text="Total de espacios:", bg="#f0f0f0", font=("Arial", 11)).grid(row=0, column=0, sticky="w", pady=8)
        tk.Entry(frame, textvariable=var_espacios, font=("Arial", 12), width=12, justify="center").grid(row=0, column=1, pady=8, padx=10)

        tk.Label(frame, text="Tiempo de gracia (min):", bg="#f0f0f0", font=("Arial", 11)).grid(row=1, column=0, sticky="w", pady=8)
        tk.Entry(frame, textvariable=var_gracia, font=("Arial", 12), width=12, justify="center").grid(row=1, column=1, pady=8, padx=10)

        tk.Label(frame, text="Monto por hora (₡):", bg="#f0f0f0", font=("Arial", 11)).grid(row=2, column=0, sticky="w", pady=8)
        tk.Entry(frame, textvariable=var_monto, font=("Arial", 12), width=12, justify="center").grid(row=2, column=1, pady=8, padx=10)

        tk.Checkbutton(frame, text="Tiene espacio para vehiculos electricos",
            variable=var_electrico, bg="#f0f0f0", font=("Arial", 11)).grid(row=3, column=0, columnspan=2, sticky="w", pady=15)

        frame_botones = tk.Frame(ventana, bg="#f0f0f0")
        frame_botones.pack(pady=10)

        def guardar_configuracion():
            try:
                total = int(var_espacios.get().strip())
                if total < 2:
                    messagebox.showerror("Error", "El estacionamiento debe tener al menos 2 espacios.")
                    return
            except ValueError:
                messagebox.showerror("Error", "Ingrese un numero valido para los espacios.")
                return
            try:
                gracia = int(var_gracia.get().strip())
                if gracia < 0:
                    messagebox.showerror("Error", "La gracia no puede ser negativa.")
                    return
            except ValueError:
                messagebox.showerror("Error", "Ingrese un numero valido para la gracia.")
                return
            try:
                monto = int(var_monto.get().strip())
                if monto <= 0:
                    messagebox.showerror("Error", "El monto debe ser mayor a 0.")
                    return
            except ValueError:
                messagebox.showerror("Error", "Ingrese un numero valido para el monto.")
                return

            confirmar = messagebox.askyesno("Confirmar", "¿Desea guardar esta configuracion?")
            if not confirmar:
                return

            self.gestor.configurar(total, gracia, monto, var_electrico.get())
            guardarArchivo("estacionamiento.bin", self.gestor)
            ventana.destroy()
            self.menu_principal()

        def continuar_sin_cambios():
            ventana.destroy()
            self.menu_principal()

        def on_closing():
            if configActual["total_espacios"] > 0:
                ventana.destroy()
                self.menu_principal()
            else:
                if messagebox.askyesno("Configuracion incompleta",
                    "No ha ingresado datos de configuracion.\n\n"
                    "¿Desea usar datos base? (20 espacios, 15 min gracia, 1000 colones)\n"
                    "Si selecciona 'No', el programa se cerrara."):
                    self.gestor.configurar(20, 15, 1000, False)
                    guardarArchivo("estacionamiento.bin", self.gestor)
                    ventana.destroy()
                    self.menu_principal()
                else:
                    self.raiz.destroy()

        ventana.protocol("WM_DELETE_WINDOW", on_closing)

        tk.Button(frame_botones, text="Guardar Configuracion", command=guardar_configuracion,
            font=("Arial", 12), bg="#27ae60", fg="white", padx=20, pady=8, cursor="hand2").pack(pady=5)

        if configActual["total_espacios"] > 0:
            tk.Button(frame_botones, text="Continuar sin cambios", command=continuar_sin_cambios,
                font=("Arial", 12), bg="#3498db", fg="white", padx=20, pady=8, cursor="hand2").pack(pady=5)
        else:
            tk.Button(frame_botones, text="Usar datos base", command=lambda: [
                self.gestor.configurar(20, 15, 1000, False),
                guardarArchivo("estacionamiento.bin", self.gestor),
                ventana.destroy(),
                self.menu_principal()
            ], font=("Arial", 12), bg="#3498db", fg="white", padx=20, pady=8, cursor="hand2").pack(pady=5)

