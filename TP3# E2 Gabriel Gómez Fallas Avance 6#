        ventanaSecundaria.geometry("500x350")
        vehiculoEnEspacio = None
        for esp in self.gestor.estacionamiento.espacios:
            if esp.numero == numero and esp.ocupado:
                vehiculoEnEspacio = esp.vehiculo
                break

        campoTexto = f"Espacio {numero + 1}"
        placaTexto = vehiculoEnEspacio.placa if vehiculoEnEspacio else "Sin datos"
        marcaTexto = vehiculoEnEspacio.marca if vehiculoEnEspacio else "Sin datos"
        colorTexto = vehiculoEnEspacio.color if vehiculoEnEspacio else "Sin datos"
        horaTexto  = vehiculoEnEspacio.hora_entrada.strftime('%d-%m-%Y %H:%M') if vehiculoEnEspacio else "Sin datos"
     

        campo = Label(ventanaSecundaria, text=f"Campo: {campoTexto}")
        campo.place(x=20, y=20)
        campo.config(font=("Courier", 12))
        placa = Label(ventanaSecundaria, text=f"Placa: {placaTexto}")
        placa.place(x=20, y=50)
        placa.config(font=("Courier", 12))
        marca = Label(ventanaSecundaria, text=f"Marca: {marcaTexto}")
        marca.place(x=20, y=80)
        marca.config(font=("Courier", 12))
        color = Label(ventanaSecundaria, text=f"Color: {colorTexto}")
        color.place(x=20, y=110)
        color.config(font=("Courier", 12))
        horaEntrada = Label(ventanaSecundaria, text=f"Hora entrada: {horaTexto}")
        horaEntrada.place(x=20, y=140)
        horaEntrada.config(font=("Courier", 12))

        tipoPago = tk.StringVar(value="Efectivo")
        tk.Label(ventanaSecundaria, text="Tipo de pago:").place(x=20, y=180)
        tk.Radiobutton(ventanaSecundaria, text="Efectivo", variable=tipoPago, value="Efectivo").place(x=20,  y=205)
        tk.Radiobutton(ventanaSecundaria, text="SINPE",    variable=tipoPago, value="SINPE").place(x=120,    y=205)
        tk.Radiobutton(ventanaSecundaria, text="Tarjeta",  variable=tipoPago, value="Tarjeta").place(x=220,  y=205)

        def pagar():
            confirmar = messagebox.askyesno("Confirmar pago", f"¿Confirma el pago con {tipoPago.get()}?")
            if not confirmar:
                return 0
            horaSalida = datetime.now()

        
            placaReal = vehiculoEnEspacio.placa if vehiculoEnEspacio else "PLACA"
            marcaReal = vehiculoEnEspacio.marca if vehiculoEnEspacio else "MARCA"
            tipoReal  = vehiculoEnEspacio.tipo_carro if vehiculoEnEspacio else "TIPO"
            horaEntradaReal = vehiculoEnEspacio.hora_entrada.strftime('%d-%m-%Y %H:%M') if vehiculoEnEspacio else ""


            datosQr = f"{placaReal}-{marcaReal}-{tipoReal}-{horaEntradaReal}"
            imgQr = qrcode.make(datosQr)
            imgQr.save("qr_temp.png")

            pdf = FPDF(orientation="P", unit="mm", format="A4")
            pdf.add_page()
            pdf.set_font("Arial", "B", 18)
            pdf.text(x=20, y=20, txt="Factura de Estacionamiento")
            pdf.set_font("Arial", "", 12)
            pdf.text(x=70, y=40, txt=f"Espacio: {numero + 1}")
            pdf.text(x=70, y=50, txt=f"Placa: {placaReal}")
            pdf.text(x=70, y=60, txt=f"Marca: {marcaReal}")
            pdf.text(x=70, y=70, txt=f"Color: {colorTexto}")
            pdf.text(x=70, y=80, txt=f"Hora entrada: {horaEntradaReal}")
            pdf.text(x=70, y=90, txt=f"Hora salida: {horaSalida.strftime('%d-%m-%Y %H:%M')}")
            pdf.text(x=70, y=100, txt=f"Tipo de pago: {tipoPago.get()}")
            pdf.image("qr_temp.png", x=20, y=110, w=50)
            nombreArchivo = f"factura_{placaReal}_{horaSalida.strftime('%d-%m-%Y_%H-%M')}.pdf"
            pdf.output(nombreArchivo)
            os.startfile(nombreArchivo)
            self.gestor.pagar_vehiculo(numero, tipoPago.get())
            guardarArchivo("estacionamiento.bin", self.gestor)
       
            self.listaBotones[numero].config(
                bg="#05c505",
                fg="black",
                command=lambda n=numero: self.abrirEspacioVerde(n)
            )
            messagebox.showinfo("Pago exitoso", f"Pago con {tipoPago.get()} registrado\nFactura: {nombreArchivo}")
            ventanaSecundaria.destroy()

        ttk.Button(ventanaSecundaria, text="Pagar",    command=pagar).place(x=100, y=270)
        ttk.Button(ventanaSecundaria, text="Regresar", command=ventanaSecundaria.destroy).place(x=250, y=270)

    def abrirEspacioVerde(self, segundoNumero):
        """
        Proposito:
        -Abrir ventana para estacionar un vehiculo en espacio libre.
        Entradas:
        -segundoNumero(int): Numero del espacio presionado
        Salidas:
        -none
        """
        ventanaSecundaria = tk.Toplevel()
        ventanaSecundaria.title(f"Espacio {segundoNumero + 1}")
        ventanaSecundaria.geometry("500x420")

        tk.Label(ventanaSecundaria, text="Placa:", font=("Courier", 12)).place(x=20, y=50)
        entryPlaca = tk.Entry(ventanaSecundaria)
        entryPlaca.place(x=200, y=50)

        tk.Label(ventanaSecundaria, text="Marca:", font=("Courier", 12)).place(x=20, y=80)
        comboMarca = ttk.Combobox(ventanaSecundaria, values=["Toyota", "Honda", "Hyundai", "Kia", "Nissan", "Ford", "Chevrolet"], state="readonly")
        comboMarca.place(x=200, y=80)

        tk.Label(ventanaSecundaria, text="Color:", font=("Courier", 12)).place(x=20, y=110)
        comboColor = ttk.Combobox(ventanaSecundaria, values=["Rojo", "Azul", "Negro", "Blanco", "Gris", "Verde", "Amarillo"], state="readonly")
        comboColor.place(x=200, y=110)

        tk.Label(ventanaSecundaria, text="Hora entrada:", font=("Courier", 12)).place(x=20, y=140)
        horaActual = datetime.now().strftime('%d-%m-%Y %H:%M')
        entryHora = tk.Entry(ventanaSecundaria)
        entryHora.insert(0, horaActual)
        entryHora.config(state="readonly")
        entryHora.place(x=200, y=140)
        tk.Label(ventanaSecundaria, text="Tipo vehiculo:", font=("Courier", 12)).place(x=20, y=170)
        comboTipo = ttk.Combobox(ventanaSecundaria,
            values=["general", "especial", "electrico"],
            state="readonly")
        comboTipo.place(x=200, y=170)
        comboTipo.set("general")
        montoPorHora = self.gestor.estacionamiento.configuracion["monto_por_hora"]
        tk.Label(ventanaSecundaria,
            text=f"Costo por hora: ₡{montoPorHora}",
            font=("Courier", 11),
            fg="#27ae60").place(x=20, y=210)

        def Estacionar():
            placaValor = entryPlaca.get()
            marcaValor = comboMarca.get()
            colorValor = comboColor.get()
            horaValor  = entryHora.get()

            if placaValor == "" or marcaValor == "" or colorValor == "" or tipoValor == "":
                messagebox.showwarning("Advertencia", "Complete todos los campos")
                return

            confirmar = messagebox.askyesno("Confirmar", f"¿Estacionar vehículo con placa {placaValor}?\nCosto por hora: ₡{montoPorHora}")
            if not confirmar:
                return

            exito, mensaje, espacio = self.gestor.estacionar_vehiculo(
                placaValor, marcaValor, colorValor, tipoValor
            )
            if not exito:
                messagebox.showerror("Error", mensaje)
                return
      

            datosQr = f"{placaValor}-{marcaValor}-{tipoValor}-{horaValor}"
            imgQr2 = qrcode.make(datosQr)
            imgQr2.save("qr_temp.png")

            pdf = FPDF(orientation="P", unit="mm", format="A4")
            pdf.add_page()
            pdf.set_font("Arial", "B", 18)
            pdf.text(x=20, y=20, txt="Voucher de Estacionamiento")
            pdf.set_font("Arial", "", 12)
            pdf.text(x=20, y=40, txt=f"Placa: {placaValor}")
            pdf.text(x=20, y=50, txt=f"Marca: {marcaValor}")
            pdf.text(x=20, y=60, txt=f"Color: {colorValor}")
            pdf.text(x=20, y=70, txt=f"Tipo: {tipoValor}")
            pdf.text(x=20, y=80, txt=f"Hora entrada: {horaValor}")
            pdf.text(x=20, y=90, txt=f"Espacio asignado: {espacio.numero + 1}")
            pdf.image("qr_temp.png", x=20, y=100, w=50)

            voucher = f"voucher_{placaValor}_{datetime.now().strftime('%d-%m-%Y_%H-%M')}.pdf"
            pdf.output(voucher)
            os.startfile(voucher)
            self.listaBotones[espacio.numero].config(
                bg="#d80505",
                command=lambda n=espacio.numero: self.abrirEspacioRojo(n)
            )
          

            messagebox.showinfo("Estacionado", f"Vehículo {placaValor} estacionado\nEspacio: {espacio.numero + 1}\nVoucher: {voucher}")
            ventanaSecundaria.destroy()

        ttk.Button(ventanaSecundaria, text="Estacionar", command=Estacionar).place(x=100, y=340)
        botonCerrar = ttk.Button(
            ventanaSecundaria,
            text="Regresar",
            command=ventanaSecundaria.destroy
        )
        botonCerrar.place(x=250, y=340)

