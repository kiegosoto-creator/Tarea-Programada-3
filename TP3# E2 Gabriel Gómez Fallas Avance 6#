    def abrirEspacioRojo(self, numero):
        """
        Proposito:
        -Abrir ventana de observacion para cualquier espacio ocupado (rojo).
        -Funciona para espacios generales y especiales ocupados.
        Entradas:
        -numero(int): Numero del espacio presionado
