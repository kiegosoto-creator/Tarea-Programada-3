    estacionar = ttk.Button(ventanaSecundaria, text="Estacionar", command=Estacionar)
    estacionar.place(x=100, y=270)
    botonCerrar = ttk.Button(
        ventanaSecundaria,
        text="Regresar",
        command=ventanaSecundaria.destroy
    )
    botonCerrar.place(x=250, y=270)

app.mainloop()
