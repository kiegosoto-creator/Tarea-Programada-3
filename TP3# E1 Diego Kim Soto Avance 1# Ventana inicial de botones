class Vehiculo:
    def __init__(self, id, placa, marca, color, tipo_carro, hora_entrada):
        """
        Proposito:
        -Crear un nuevo objeto Vehiculo con los datos del vehiculo que 
         ingresa al estacionamiento.
        Funcionamiento:
        -Asigna los valores recibidos a los atributos del objeto. 
         Inicializa hora_salida, tipo_pago y monto como valores vacios o cero.
         Asigna -1 a espacio_asignado para indicar que aun no tiene espacio.
        Entradas:
        -id(int): Identificador unico del vehiculo
        -placa(str): Placa del vehiculo
        -marca(str): Marca del vehiculo
        -color(str): Color del vehiculo
        -tipo_carro(str): Tipo de vehiculo (general, especial, electrico)
        -hora_entrada(datetime): Fecha y hora de ingreso al estacionamiento
        Salidas:
        -none
        """
        self.id = id
        self.placa = placa
        self.marca = marca
        self.color = color
        self.tipo_carro = tipo_carro
        self.hora_entrada = hora_entrada
        self.hora_salida = None
        self.tipo_pago = None
        self.monto = 0
        self.espacio_asignado = -1

class Espacio:
    def __init__(self, numero, tipo):
        """
        Proposito:
        -Crear un nuevo espacio de estacionamiento.
        Funcionamiento:
        -Asigna el numero y tipo al espacio. Inicializa el espacio como libre (ocupado=False) y
         sin vehiculo (vehiculo=None).
        Entradas:
        -numero(int): Numero identificador del espacio
        -tipo(str): Tipo de espacio (general, especial, electrico)
        Salidas:
        -none
        """
        self.numero = numero
        self.tipo = tipo
        self.ocupado = False
        self.vehiculo = None
    
    def estacionar(self, vehiculo):
        """
        Proposito:
        -Asignar un vehiculo a un espacio libre.
        Funcionamiento:
        -Verifica si el espacio esta libre. Si lo esta, marca el espacio como ocupado, guarda el vehiculo, y actualiza el espacio_asignado del vehiculo con el numero del espacio. Retorna True si se estaciono correctamente.
        Entradas:
        -vehiculo(Vehiculo): Objeto vehiculo que se va a estacionar
        Salidas:
        -True(bool): Indica que el vehiculo se estaciono correctamente
        -False(bool): Indica que el espacio ya estaba ocupado
        """
        if not self.ocupado:
            self.ocupado = True
            self.vehiculo = vehiculo
            vehiculo.espacio_asignado = self.numero
            return True
        return False
    
    def liberar(self):
        """
        Proposito:
        -Liberar un espacio que estaba ocupado.
        Funcionamiento:
        -Marca el espacio como libre (ocupado=False) y elimina la referencia al vehiculo (vehiculo=None).
        Entradas:
        -none
        Salidas:
        -True(bool): Indica que el espacio se libero correctamente
        """
        self.ocupado = False
        self.vehiculo = None
        return True

class Estacionamiento:
    """
    Proposito:
    -Representa el estacionamiento completo con sus espacios y configuracion.
    Funcionamiento:
    -Contiene una lista de objetos Espacio y un diccionario de configuracion.
    -Permite configurar el estacionamiento, buscar espacios libres y obtener resumenes.
    Entradas:
    -none
    Salidas:
    -none
    """
    def __init__(self):
        """
        Proposito:
        -Crear un nuevo estacionamiento sin espacios.
        Funcionamiento:
        -Inicializa la lista de espacios vacia. Crea un diccionario de configuracion con valores por defecto.
        Entradas:
        -none
        Salidas:
        -none
        """
        self.espacios = []
        self.configuracion = {
            "total_espacios": 0,
            "espacios_especiales": 0,
            "tiempo_gracia": 15,
            "monto_por_hora": 1000,
            "tiene_electrico": False
        }
    
    def configurar(self, total, tiempo_gracia, monto_por_hora, tiene_electrico):
        """
        Proposito:
        -Configurar el estacionamiento y generar todos los espacios.
        Funcionamiento:
        -Calcula el 5% de espacios especiales (minimo 2). Guarda la configuracion.
        -Crea espacios generales, especiales y electrico (si aplica) en ese orden.
        Entradas:
        -total(int): Total de espacios del estacionamiento
        -tiempo_gracia(int): Minutos de gracia sin cobro
        -monto_por_hora(int): Monto en colones por hora
        -tiene_electrico(bool): True si hay espacio para vehiculos electricos
        Salidas:
        -none
        """
        especiales = max(2, int(total * 0.05))
        
        self.configuracion["total_espacios"] = total
        self.configuracion["espacios_especiales"] = especiales
        self.configuracion["tiempo_gracia"] = tiempo_gracia
        self.configuracion["monto_por_hora"] = monto_por_hora
        self.configuracion["tiene_electrico"] = tiene_electrico
        
        self.espacios = []
        
        generales = total - especiales - (1 if tiene_electrico else 0)
        for i in range(generales):
            self.espacios.append(Espacio(i, "general"))
        
        for i in range(especiales):
            self.espacios.append(Espacio(len(self.espacios), "especial"))
        
        if tiene_electrico:
            self.espacios.append(Espacio(len(self.espacios), "electrico"))
    
    def buscar_espacio_libre(self, tipo_vehiculo):
        """
        Proposito:
        -Encontrar un espacio libre segun el tipo de vehiculo.
        Funcionamiento:
        -Recorre todos los espacios. Para cada espacio libre, verifica si el tipo del espacio
         es compatible con el tipo del vehiculo.
         - Generales pueden usar cualquier espacio excepto electricos.
         - Especiales solo usan especiales.
         - Electricos solo usan electricos.
        Entradas:
        -tipo_vehiculo(str): Tipo de vehiculo (general, especial, electrico)
        Salidas:
        -Espacio(object): Retorna el objeto Espacio libre y compatible
        -None: Retorna None si no hay espacio disponible
        """
        for espacio in self.espacios:
            if not espacio.ocupado:
                if tipo_vehiculo == "general":
                    if espacio.tipo != "electrico":
                        return espacio
                elif tipo_vehiculo == "especial":
                    if espacio.tipo == "especial":
                        return espacio
                elif tipo_vehiculo == "electrico":
                    if espacio.tipo == "electrico":
                        return espacio
        return None
    
    def obtener_resumen(self):
        """
        Proposito:
        -Obtener un resumen del estado actual del estacionamiento.
        Funcionamiento:
        -Recorre todos los espacios y cuenta cuantos hay de cada tipo y cuantos estan ocupados.
        Entradas:
        -none
        Salidas:
        -resumen(dict): Diccionario con totales (total, ocupados, generales, especiales, electricos)
        """
        resumen = {
            "total": len(self.espacios),
            "ocupados": 0,
            "generales": 0,
            "especiales": 0,
            "electricos": 0,
            "generales_ocupados": 0,
            "especiales_ocupados": 0,
            "electricos_ocupados": 0
        }
        for espacio in self.espacios:
            if espacio.tipo == "general":
                resumen["generales"] += 1
                if espacio.ocupado:
                    resumen["generales_ocupados"] += 1
            elif espacio.tipo == "especial":
                resumen["especiales"] += 1
                if espacio.ocupado:
                    resumen["especiales_ocupados"] += 1
            else:
                resumen["electricos"] += 1
                if espacio.ocupado:
                    resumen["electricos_ocupados"] += 1

            if espacio.ocupado:
                resumen["ocupados"] += 1
        return resumen

class GestorEstacionamiento:
    """
    Proposito:
    -Maneja toda la logica del estacionamiento conectando Vehiculo, Espacio y Estacionamiento.
    Funcionamiento:
    -Contiene un objeto Estacionamiento, listas de vehiculos y facturas, y el contador de IDs.
    -Permite configurar, estacionar, pagar y calcular montos.
    Entradas:
    -none
    Salidas:
    -none
    """
    def __init__(self):
        """
        Proposito:
        -Crear el gestor principal del estacionamiento.
        Funcionamiento:
        -Crea un objeto Estacionamiento. Inicializa la lista de vehiculos (historial completo),
         la lista de facturas del dia, y el contador de IDs en 1.
        Entradas:
        -none
        Salidas:
        -none
        """
        self.estacionamiento = Estacionamiento()
        self.vehiculos = []
        self.facturas_dia = []
        self.proximo_id = 1
    
    def configurar(self, total, gracia, monto, tiene_electrico):
        """
        Proposito:
        -Configurar el estacionamiento a traves del gestor.
        Funcionamiento:
        -Llama al metodo configurar del objeto Estacionamiento con los parametros recibidos.
        Entradas:
        -total(int): Total de espacios
        -gracia(int): Minutos de gracia
        -monto(int): Monto por hora en colones
        -tiene_electrico(bool): True si hay espacio para electricos
        Salidas:
        -none
        """
        self.estacionamiento.configurar(total, gracia, monto, tiene_electrico)
    
    def estacionar_vehiculo(self, placa, marca, color, tipo_carro):
        """
        Proposito:
        -Registrar la entrada de un nuevo vehiculo al estacionamiento.
        Funcionamiento:
        -Busca un espacio libre compatible. Si no hay, retorna error.
        -Si hay, crea un Vehiculo, asigna espacio, guarda en historial y retorna exito.
        Entradas:
        -placa(str): Placa del vehiculo
        -marca(str): Marca del vehiculo
        -color(str): Color del vehiculo
        -tipo_carro(str): Tipo de vehiculo (general, especial, electrico)
        Salidas:
        -True(bool): Indica exito
        -False(bool): Indica error
        -mensaje(str): Mensaje de exito o error
        -espacio(Espacio): Objeto Espacio asignado o None
        """
        espacio = self.estacionamiento.buscar_espacio_libre(tipo_carro)
        if espacio is None:
            return False, "No hay espacio disponible para este tipo", None
        vehiculo = Vehiculo(
            id=self.proximo_id,
            placa=placa,
            marca=marca,
            color=color,
            tipo_carro=tipo_carro,
            hora_entrada=datetime.now()
        )
        espacio.estacionar(vehiculo)
        self.vehiculos.append(vehiculo)
        self.proximo_id += 1
        return True, "Vehiculo estacionado", espacio
    
    def pagar_vehiculo(self, numero_espacio, tipo_pago):
        """
        Proposito:
        -Procesar el pago de un vehiculo y liberar su espacio.
        Funcionamiento:
        -Busca el espacio ocupado con el numero indicado. Si existe, registra la hora de salida,
         calcula el monto, guarda el tipo de pago, agrega a facturas del dia y libera el espacio.
        Entradas:
        -numero_espacio(int): Numero del espacio donde esta el vehiculo
        -tipo_pago(str): Metodo de pago (efectivo, sinpe, tarjeta)
        Salidas:
        -True(bool): Indica exito
        -False(bool): Indica error
        -mensaje(str): Mensaje de exito o error
        -vehiculo(Vehiculo): Objeto Vehiculo que pago o None
        """
        for espacio in self.estacionamiento.espacios:
            if espacio.numero == numero_espacio and espacio.ocupado:
                vehiculo = espacio.vehiculo
                hora_salida = datetime.now()
                vehiculo.hora_salida = hora_salida
                vehiculo.tipo_pago = tipo_pago
                vehiculo.monto = self.calcular_monto(
                    vehiculo.hora_entrada, 
                    hora_salida
                )
                self.facturas_dia.append(vehiculo)
                espacio.liberar()
                return True, "Pago procesado", vehiculo
        return False, "No hay vehiculo en este espacio", None
    
    def calcular_monto(self, hora_entrada, hora_salida):
        """
        Proposito:
        -Calcular el monto a pagar segun el tiempo de estadia.
        Funcionamiento:
        -Calcula los minutos entre entrada y salida. Si es menor o igual a la gracia, monto=0.
        -Si no, resta la gracia, convierte a horas (redondeando arriba) y multiplica por tarifa.
        Entradas:
        -hora_entrada(datetime): Fecha y hora de ingreso
        -hora_salida(datetime): Fecha y hora de salida
        Salidas:
        -monto(int): Monto en colones a pagar
        """
        diferencia = hora_salida - hora_entrada
        minutos = diferencia.total_seconds() / 60
        gracia = self.estacionamiento.configuracion["tiempo_gracia"]
        tarifa = self.estacionamiento.configuracion["monto_por_hora"]
        if minutos <= gracia:
            return 0
        minutos_cobrables = minutos - gracia
        horas = int(minutos_cobrables / 60)
        if minutos_cobrables % 60 > 0:
            horas += 1
        return horas * tarifa

