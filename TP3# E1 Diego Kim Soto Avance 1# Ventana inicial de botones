def existeArchivo(nombre_archivo):
    """
    Proposito:
    -Al ingresar el nombre de un archivo, esta funcion retorna True, si el archivo existe,
    y False si NO existe.
    Funcionamiento:
    -La funcion trata de abrir en modo lectura binaria, el archivo nombrado por el parametro(nombre_archivo)
     dentro de una variable(archivo). Cierra archivo, y retorna True.
    -Pero si hay una falla al ejecutar, se asume que no encontro el archivo, al no poder leerlo. Por
     lo que el archivo no existe, pasa a la excepcion y retorna False.
    Entradas:
    -nombre_archivo(str): Es el nombre del archivo, que deseamos saber si existe o no existe.
    Salidas:
    -True(bool): Retorna cuando SI existe el archivo buscado.
    -False(bool): Retorna cuando NO existe el archivo buscado.
    """
    try:
        with open(nombre_archivo,'rb') as archivo:
            return True
    except FileNotFoundError:
        return False

def guardarArchivo(nombre_archivo,lista):
    """
    Proposito:
    -Guardar la lista de objetos actualizada, en el archivo binario.
    Funcionamiento:
    -La funcion abre con with open el archivo, nombrado por el string(nombre_archivo).
    -Y guarda toda la lista(lista) con pickle.dump, dentro del archivo, actualizandolo.
    Entradas:
    -nombre_archivo(str): Es el nombre del archivo, que deseamos actualizar.
    -lista(list): Es la lista actualizada, que queremos guardar en el archivo binario.
    Salidas:
    -none
    """
    with open(nombre_archivo,'wb') as archivo:
        pickle.dump(lista,archivo)

def cargarArchivo(nombre_archivo):
    """
    Proposito:
    -Retornar el valor de un archivo nombrado por un string(nombre_archivo).
    Funcionamiento:
    -La funcion, abre en modo lectura binaria, al archivo nombrado por el parametro
     (nombre_archivo), como una variable(archivo).
    -Y retorna el contenido del archivo con return pickle.load(archivo).
    Entradas:
    -nombre_archivo(str): Es el nombre del archivo, que deseamos extraer el valor de.
    Salidas:
    -"En el caso de este programa, una lista"(list): Lista de objetos.
    """
    with open(nombre_archivo,'rb') as archivo:
        return pickle.load(archivo)

