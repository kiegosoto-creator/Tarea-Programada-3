        Proposito:
        -Mostrar ventana para ingresar configuracion inicial del estacionamiento.
        Funcionamiento:
        -Crea una ventana con campos para total, gracia, monto y electricos.
        -Si el usuario confirma, guarda y genera espacios.
        -Si el usuario cierra la ventana, pregunta si quiere usar datos base.
        -Si no confirma, usa datos base (20 espacios, 15 min gracia, 1000 colones).
        Entradas:
        -none
        Salidas:
        -none
        """
        ventana = tk.Toplevel(self.raiz)
        ventana.title("Configuracion inicial")
        ventana.geometry("400x400")
        ventana.configure(bg="#f0f0f0")
        ventana.resizable(False, False)
    
        # Centrar ventana
        ventana.update_idletasks()
        x = (ventana.winfo_screenwidth() // 2) - (400 // 2)
        y = (ventana.winfo_screenheight() // 2) - (400 // 2)
        ventana.geometry(f"+{x}+{y}")
    
        # Hacer que la ventana sea modal
        ventana.transient(self.raiz)
        ventana.grab_set()
    
        # Variables
        var_espacios = tk.StringVar()
        var_gracia = tk.StringVar(value="15")
        var_monto = tk.StringVar(value="1000")
        var_electrico = tk.BooleanVar(value=False)
    
        # Titulo
        tk.Label(
            ventana,
            text="Configuracion del Estacionamiento",
            font=("Arial", 16, "bold"),
            bg="#f0f0f0"
        ).pack(pady=20)
    
        tk.Label(
            ventana,
            text="No se encontro una base de datos.\nIngrese los datos de configuracion:",
            font=("Arial", 11),
            bg="#f0f0f0"
        ).pack(pady=5)
    
        # Frame para campos
        frame = tk.Frame(ventana, bg="#f0f0f0")
        frame.pack(pady=20, padx=40)
    
        # Campo 1: Total de espacios
        tk.Label(
            frame,
            text="Total de espacios:",
            bg="#f0f0f0",
            font=("Arial", 11)
        ).grid(row=0, column=0, sticky="w", pady=8)
        tk.Entry(
            frame,
            textvariable=var_espacios,
            font=("Arial", 12),
            width=12,
            justify="center"
        ).grid(row=0, column=1, pady=8, padx=10)
    
        # Campo 2: Tiempo de gracia
        tk.Label(
            frame,
            text="Tiempo de gracia (min):",
            bg="#f0f0f0",
            font=("Arial", 11)
        ).grid(row=1, column=0, sticky="w", pady=8)
        tk.Entry(
            frame,
            textvariable=var_gracia,
            font=("Arial", 12),
            width=12,
            justify="center"
        ).grid(row=1, column=1, pady=8, padx=10)
    
        # Campo 3: Monto por hora
        tk.Label(
            frame,
            text="Monto por hora (₡):",
            bg="#f0f0f0",
            font=("Arial", 11)
        ).grid(row=2, column=0, sticky="w", pady=8)
        tk.Entry(
            frame,
            textvariable=var_monto,
            font=("Arial", 12),
            width=12,
            justify="center"
        ).grid(row=2, column=1, pady=8, padx=10)
    
        # Campo 4: Checkbox electricos
        tk.Checkbutton(
            frame,
            text="Tiene espacio para vehiculos electricos",
            variable=var_electrico,
            bg="#f0f0f0",
            font=("Arial", 11)
        ).grid(row=3, column=0, columnspan=2, sticky="w", pady=15)
    
        # Botones
        frame_botones = tk.Frame(ventana, bg="#f0f0f0")
        frame_botones.pack(pady=20)
    
        def guardar_configuracion():
            """Guarda la configuracion ingresada por el usuario"""
            try:
                total = int(var_espacios.get().strip())
                if total < 2:
                    messagebox.showerror("Error", "El estacionamiento debe tener al menos 2 espacios.")
                    return
            except ValueError:
                messagebox.showerror("Error", "Ingrese un numero valido para los espacios.")
                return
        
            try:
                gracia = int(var_gracia.get().strip())
                if gracia < 0:
                    messagebox.showerror("Error", "La gracia no puede ser negativa.")
                    return
            except ValueError:
                messagebox.showerror("Error", "Ingrese un numero valido para la gracia.")
                return
        
            try:
                monto = int(var_monto.get().strip())
                if monto <= 0:
                    messagebox.showerror("Error", "El monto debe ser mayor a 0.")
                    return
            except ValueError:
                messagebox.showerror("Error", "Ingrese un numero valido para el monto.")
                return
        
            # Configurar el estacionamiento
            self.gestor.configurar(total, gracia, monto, var_electrico.get())
        
            # Guardar en archivo
            guardarArchivo("estacionamiento.bin", self.gestor)
        
            ventana.destroy()
            self.menu_principal()
    
        def usar_datos_base():
            """Usa datos base si el usuario no quiere configurar"""
            # Datos base: 20 espacios, 15 min gracia, 1000 colones, sin electricos
            self.gestor.configurar(20, 15, 1000, False)
            guardarArchivo("estacionamiento.bin", self.gestor)
            ventana.destroy()
            self.menu_principal()
    
        def on_closing():
            """Cuando el usuario cierra la ventana con la X"""
            if messagebox.askyesno(
                "Configuracion incompleta",
                "No ha ingresado datos de configuracion.\n\n"
                "¿Desea usar datos base? (20 espacios, 15 min gracia, 1000 colones)\n"
                "Si selecciona 'No', el programa se cerrara."
            ):
                usar_datos_base()
            else:
                self.raiz.destroy()
    
        # Configurar el cierre de la ventana
        ventana.protocol("WM_DELETE_WINDOW", on_closing)
    
        # Botones
        tk.Button(
            frame_botones,
            text="Guardar Configuracion",
            command=guardar_configuracion,
            font=("Arial", 12),
            bg="#27ae60",
            fg="white",
            padx=20,
            pady=8,
            cursor="hand2"
        ).pack(pady=5)
    
        tk.Button(
            frame_botones,
            text="Usar datos base",
            command=usar_datos_base,
            font=("Arial", 12),
